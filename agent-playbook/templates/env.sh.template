#!/usr/bin/env bash
# .claude/env.sh — toolchain bindings for the agent team.
#
# Sourced by /execute preflight and by SWE / QA agents before they run tests
# or linters. Resolves a working Python interpreter even when Git Bash on
# Windows lacks the tool in its PATH, and exposes uniform command aliases so
# the agent prompts do not need to guess whether to call `pytest` or
# `py -m pytest` on a given host.
#
# Exports:
#   PY     — path (or name) of the Python launcher that works on this host
#   PYTEST — full test-runner command, e.g. "${PY} -m pytest"
#   RUFF / BLACK / ISORT / PIP — linters and package manager, same pattern
#
# Provides:
#   check_toolchain  — returns non-zero if any of pytest/ruff/black/isort is
#                      not importable by ${PY}. Prints a diagnostic to stderr
#                      for each missing tool. Use this at the top of any
#                      skill or agent that is about to run tests.

_find_python() {
    # Canonical version lives in scripts/lib/find-python.sh — keep in sync.
    # Prefer tools already on PATH.
    for cand in python3 python py; do
        if command -v "$cand" >/dev/null 2>&1 \
           && "$cand" --version >/dev/null 2>&1; then
            echo "$cand"
            return 0
        fi
    done

    # Windows fallback — Git Bash often does not expose the launcher.
    for p in /c/Users/*/AppData/Local/Programs/Python/*/python.exe \
             /c/Python*/python.exe \
             "/c/Program Files/Python"*"/python.exe"; do
        if [[ -x "$p" ]]; then
            echo "$p"
            return 0
        fi
    done

    return 1
}

PY="$(_find_python)" || {
    echo "env.sh: ERROR — no Python interpreter found on PATH or in common Windows locations." >&2
    return 1 2>/dev/null || exit 1
}

export PY
export PYTEST="${PY} -m pytest"
export RUFF="${PY} -m ruff"
export BLACK="${PY} -m black"
export ISORT="${PY} -m isort"
export PIP="${PY} -m pip"

check_toolchain() {
    local missing=0
    for tool in pytest ruff black isort; do
        if ! ${PY} -m "${tool}" --version >/dev/null 2>&1; then
            echo "env.sh: WARNING — '${PY} -m ${tool} --version' failed (tool missing or broken)." >&2
            missing=$((missing + 1))
        fi
    done
    return "${missing}"
}

# Resolve .claude/ directory (the directory holding this env.sh).
_CLAUDE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source project-specific identifiers (GitHub project IDs, skills path).
# This file is per-project — see .claude/PORTING.md for setup instructions.
if [[ -f "${_CLAUDE_DIR}/project.env" ]]; then
    # shellcheck disable=SC1090
    source "${_CLAUDE_DIR}/project.env"
else
    echo "env.sh: WARNING — .claude/project.env not found. Tracker commands will use unset variables." >&2
fi

# Derive TRACKER_BACKEND from the `tracker:` line of CLAUDE.md if not already
# set in the environment. Accepted values: file, github-issues, azure-boards.
# Defaults to "file" if CLAUDE.md is missing or the line is absent.
if [[ -z "${TRACKER_BACKEND:-}" ]]; then
    _CLAUDE_MD="${_CLAUDE_DIR}/../CLAUDE.md"
    if [[ -f "${_CLAUDE_MD}" ]]; then
        TRACKER_BACKEND="$(awk '
            /^tracker:[[:space:]]*/ {
                sub(/^tracker:[[:space:]]*/, "", $0)
                sub(/[[:space:]]*#.*$/, "", $0)
                gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0)
                print $0
                exit
            }' "${_CLAUDE_MD}")"
    fi
    : "${TRACKER_BACKEND:=file}"
    export TRACKER_BACKEND
    unset _CLAUDE_MD
fi

# Resolve SUPERPOWERS_SKILLS_DIR if not set (or set but pointing nowhere).
# Order:
#   1. Honor an explicit, valid SUPERPOWERS_SKILLS_DIR
#   2. Claude Code plugin install:
#        ~/.claude/plugins/cache/claude-plugins-official/superpowers/*/skills
#      (the most recent version directory wins)
#   3. Common git-clone locations on this host
#   4. Print a clear error with the install URL
#
# Install (one of):
#   - Claude Code:  /plugin install superpowers@claude-plugins-official
#   - Other tools:  git clone https://github.com/obra/superpowers ~/superpowers
_resolve_superpowers_skills_dir() {
    if [[ -n "${SUPERPOWERS_SKILLS_DIR:-}" ]] \
       && [[ -d "${SUPERPOWERS_SKILLS_DIR}" ]] \
       && compgen -G "${SUPERPOWERS_SKILLS_DIR}/*/SKILL.md" >/dev/null 2>&1; then
        return 0
    fi

    local plugin_glob="${HOME}/.claude/plugins/cache/claude-plugins-official/superpowers/*/skills"
    local latest=""
    # shellcheck disable=SC2086
    for cand in $(ls -d ${plugin_glob} 2>/dev/null | sort -V); do
        [[ -d "${cand}" ]] && latest="${cand}"
    done
    if [[ -n "${latest}" ]] && compgen -G "${latest}/*/SKILL.md" >/dev/null 2>&1; then
        export SUPERPOWERS_SKILLS_DIR="${latest}"
        return 0
    fi

    for cand in \
        "${HOME}/superpowers/skills" \
        "${HOME}/github/superpowers/skills" \
        "${HOME}/code/superpowers/skills" \
        "../../github/superpowers/skills"; do
        if [[ -d "${cand}" ]] \
           && compgen -G "${cand}/*/SKILL.md" >/dev/null 2>&1; then
            export SUPERPOWERS_SKILLS_DIR="${cand}"
            return 0
        fi
    done

    cat >&2 <<'EOF'
env.sh: WARNING — superpowers skills not found.
  Install one of:
    Claude Code:  /plugin install superpowers@claude-plugins-official
    Other tools:  git clone https://github.com/obra/superpowers ~/superpowers
  Then either let env.sh auto-detect, or set SUPERPOWERS_SKILLS_DIR explicitly
  in .claude/project.env (must point at the directory containing <skill>/SKILL.md).
EOF
    return 1
}
_resolve_superpowers_skills_dir || true

# Source the tracker dispatcher. After this, every tracker_<verb> bash
# function (list_issues, view_issue, transition, etc.) is available in the
# calling shell. Routes to the file/github/azure backend based on
# TRACKER_BACKEND. See lib/tracker/_docs/interface-spec.md for the contract.
_TRACKER_DISPATCHER="${_CLAUDE_DIR}/lib/tracker/tracker.sh"
if [[ -f "${_TRACKER_DISPATCHER}" ]]; then
    # shellcheck disable=SC1090
    source "${_TRACKER_DISPATCHER}"
else
    echo "env.sh: WARNING — .claude/lib/tracker/tracker.sh not found. tracker_* verbs will be unavailable." >&2
fi
unset _TRACKER_DISPATCHER _CLAUDE_DIR

# Agent and skill prompts must call the tracker_* dispatcher (e.g. tracker_transition,
# tracker_comment_issue, tracker_close_issue) rather than backend-specific helpers.
# The dispatcher routes to the right backend (file / GitHub / Azure) and bundles
# all related field / label / tag / state updates into one atomic call.
