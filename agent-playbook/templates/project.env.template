#!/usr/bin/env bash
# .claude/project.env — project-specific identifiers for the agent team.
#
# Sourced automatically by .claude/env.sh. Holds the values that vary between
# projects: GitHub repo/project IDs and the path to the superpowers skills
# directory.
#
# init-project.sh fills in GH_OWNER at copy time (via `gh api user --jq .login`).
# The other values must be resolved by hand (or by the on-call agent during
# repo initialisation) — see .claude/PORTING.md for the gh commands that
# produce each ID.
#
# This file is committed to the repo. The values are not secrets — GitHub
# Project IDs and field/option IDs are scoped to the project board and only
# usable by someone with permissions on that board.

# --- GitHub repo & project board ---------------------------------------
export GH_OWNER="__OWNER__"
export GH_REPO=""
export GH_PROJECT_NUMBER=
export GH_PROJECT_ID=""

# --- GitHub Project field IDs (resolve via: gh project field-list <your-project-number> --owner <your-github-user> --format json) ---
export GH_FIELD_PIPELINE=""
export GH_FIELD_AGENT=""
export GH_FIELD_STATUS=""
export GH_FIELD_QA_CYCLE=""

# --- Pipeline option IDs (single-select values on the Pipeline field) --
export GH_PIPELINE_BACKLOG=""
export GH_PIPELINE_DEVELOPMENT=""
export GH_PIPELINE_QA=""
export GH_PIPELINE_ACCEPTANCE=""
export GH_PIPELINE_DOCUMENTATION=""
export GH_PIPELINE_DONE=""
export GH_PIPELINE_BLOCKED=""

# --- Agent option IDs (single-select values on the Agent field) --------
export GH_AGENT_SWE=""
export GH_AGENT_QA=""
export GH_AGENT_PM=""
export GH_AGENT_TECHWRITER=""
export GH_AGENT_HUMAN=""

# --- Status option IDs (single-select values on the Status field) ------
export GH_STATUS_BACKLOG=""
export GH_STATUS_IN_DOCS=""
export GH_STATUS_DONE=""

# --- Azure DevOps Boards (only when tracker: azure-boards) -------------
# Resolve via:
#   az devops project show --org <org-url> --project <name>     # project info
#   az repos show --org <org-url> -p <project> -r <repo>         # repo info
# `az login` must have run; the azure-devops extension must be installed
# (az extension add --name azure-devops). AZ_ORG accepts either a slug
# ("myorg") or a full URL ("https://dev.azure.com/myorg").
export AZ_ORG=""
export AZ_PROJECT=""
export AZ_REPO=""

# --- Optional Azure DevOps tunables ------------------------------------
# AZ_AREA_PATH defaults to AZ_PROJECT; AZ_WORK_ITEM_TYPE defaults to "Task"
# (works on the Agile process template). Set AZ_ITERATION_PATH to assign
# new work items to a specific sprint; leave blank for backlog.
export AZ_AREA_PATH=""
export AZ_ITERATION_PATH=""
export AZ_WORK_ITEM_TYPE=""

# --- Optional: System.State name overrides for non-Agile templates -----
# tracker_azure.sh maps the pipeline onto Agile values by default
# (New / Active / Resolved / Closed). Override per-process below if your
# project uses Scrum / CMMI / Basic. Verify your project's actual state
# names with:
#   az boards work-item show --id <existing-id> -o json | jq '.fields["System.State"]'
#
#   Scrum:   AZ_STATE_NEW=New        AZ_STATE_ACTIVE=Committed
#            AZ_STATE_RESOLVED=Done  AZ_STATE_CLOSED=Done
#   CMMI:    AZ_STATE_NEW=Proposed   AZ_STATE_ACTIVE=Active
#            AZ_STATE_RESOLVED=Resolved  AZ_STATE_CLOSED=Closed
#   Basic:   AZ_STATE_NEW="To Do"    AZ_STATE_ACTIVE=Doing
#            AZ_STATE_RESOLVED=Doing AZ_STATE_CLOSED=Done
export AZ_STATE_NEW=""
export AZ_STATE_ACTIVE=""
export AZ_STATE_RESOLVED=""
export AZ_STATE_CLOSED=""

# --- Superpowers skills location ---------------------------------------
# Path to the directory that contains the superpowers <skill-name>/SKILL.md
# files. Default is relative to the project root. Override with an absolute
# path if your skills live elsewhere on this host (e.g. a shared user-global
# location).
export SUPERPOWERS_SKILLS_DIR="${SUPERPOWERS_SKILLS_DIR:-../../github/superpowers/skills}"
